---
---

<section id="contacto" class="py-24 px-4 bg-brand-dark">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16" data-aos="fade-up">
      <p class="text-brand-blue text-sm font-semibold tracking-widest uppercase mb-3">
        Hablemos
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-white mb-4">
        ¿Listo para digitalizar tu negocio?
      </h2>
      <p class="text-brand-muted max-w-xl mx-auto">
        Cuéntanos sobre tu proyecto y te contactamos en menos de 24 horas.
      </p>
      <div class="w-16 h-1 bg-gradient-to-r from-brand-blue to-brand-purple rounded mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Left: info -->
      <div data-aos="fade-right">
        <h3 class="text-2xl font-bold text-brand-white mb-6">
          Estamos aquí para ayudarte
        </h3>
        <p class="text-brand-muted leading-relaxed mb-8">
          Somos un equipo joven y apasionado con sede en Santiago de Chile.
          Trabajamos con negocios locales para llevarlos al mundo digital de
          forma efectiva y sin complicaciones.
        </p>

        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-brand-blue/10 rounded-xl flex items-center justify-center text-brand-blue flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="text-brand-muted text-sm">Email</p>
              <p class="text-brand-white font-medium">hola@reclub.cl</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-brand-blue/10 rounded-xl flex items-center justify-center text-brand-blue flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="text-brand-muted text-sm">WhatsApp</p>
              <p class="text-brand-white font-medium">+56 9 XXXX XXXX</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-brand-blue/10 rounded-xl flex items-center justify-center text-brand-blue flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="text-brand-muted text-sm">Ubicación</p>
              <p class="text-brand-white font-medium">Santiago, Chile</p>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="mt-8 flex gap-3">
          <a
            href="#"
            class="w-10 h-10 bg-brand-card border border-brand-border rounded-xl flex items-center justify-center text-brand-muted hover:text-brand-blue hover:border-brand-blue/40 transition-all"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="#"
            class="w-10 h-10 bg-brand-card border border-brand-border rounded-xl flex items-center justify-center text-brand-muted hover:text-brand-blue hover:border-brand-blue/40 transition-all"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div data-aos="fade-left">
        <div id="form-container" class="bg-brand-card border border-brand-border rounded-2xl p-8">
          <form
            id="contact-form"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            class="space-y-5"
          >
            <!-- Spam prevention -->
            <input type="text" name="_gotcha" style="display:none" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="nombre" class="block text-brand-muted text-sm font-medium mb-2">
                  Nombre
                </label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  placeholder="Tu nombre"
                  class="w-full bg-brand-dark border border-brand-border rounded-xl px-4 py-3 text-brand-white placeholder:text-brand-muted/50 focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-colors text-sm"
                />
              </div>
              <div>
                <label for="email" class="block text-brand-muted text-sm font-medium mb-2">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="tu@email.com"
                  class="w-full bg-brand-dark border border-brand-border rounded-xl px-4 py-3 text-brand-white placeholder:text-brand-muted/50 focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-colors text-sm"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="telefono" class="block text-brand-muted text-sm font-medium mb-2">
                  Teléfono
                </label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  placeholder="+56 9 XXXX XXXX"
                  class="w-full bg-brand-dark border border-brand-border rounded-xl px-4 py-3 text-brand-white placeholder:text-brand-muted/50 focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-colors text-sm"
                />
              </div>
              <div>
                <label for="plan" class="block text-brand-muted text-sm font-medium mb-2">
                  Plan de interés
                </label>
                <select
                  id="plan"
                  name="plan"
                  class="w-full bg-brand-dark border border-brand-border rounded-xl px-4 py-3 text-brand-white focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-colors text-sm appearance-none"
                >
                  <option value="" class="bg-brand-dark">Selecciona un plan</option>
                  <option value="starter" class="bg-brand-dark">Starter — $120.000</option>
                  <option value="esencial" class="bg-brand-dark">Esencial — $220.000</option>
                  <option value="profesional" class="bg-brand-dark">Profesional — $380.000</option>
                  <option value="premium" class="bg-brand-dark">Premium — $550.000</option>
                  <option value="elite" class="bg-brand-dark">Elite — $790.000</option>
                  <option value="no-se" class="bg-brand-dark">No lo sé aún</option>
                </select>
              </div>
            </div>

            <div>
              <label for="mensaje" class="block text-brand-muted text-sm font-medium mb-2">
                Mensaje (opcional)
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                placeholder="Cuéntanos sobre tu negocio..."
                class="w-full bg-brand-dark border border-brand-border rounded-xl px-4 py-3 text-brand-white placeholder:text-brand-muted/50 focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-colors text-sm resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full bg-gradient-to-r from-brand-blue to-brand-purple text-white py-4 rounded-xl font-semibold hover:scale-[1.02] transition-transform duration-200 shadow-lg shadow-brand-blue/25 flex items-center justify-center gap-2"
            >
              <span id="btn-text">Enviar mensaje</span>
              <svg id="btn-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="hidden w-5 h-5 animate-spin">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>

            <div id="error-msg" class="hidden text-red-400 text-sm text-center">
              Hubo un error al enviar. Por favor intenta de nuevo.
            </div>
          </form>
        </div>

        <!-- Success state (hidden by default) -->
        <div id="success-state" class="hidden bg-brand-card border border-brand-border rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-emerald-400/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-emerald-400">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-white mb-2">¡Mensaje enviado!</h3>
          <p class="text-brand-muted">Nos pondremos en contacto contigo pronto. ¡Gracias por tu interés en ReClub!</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContainer = document.getElementById('form-container') as HTMLElement;
  const successState = document.getElementById('success-state') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const errorMsg = document.getElementById('error-msg') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    submitBtn.disabled = true;
    btnText.textContent = 'Enviando...';
    btnSpinner.classList.remove('hidden');
    errorMsg.classList.add('hidden');

    try {
      const data = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        formContainer.classList.add('hidden');
        successState.classList.remove('hidden');
      } else {
        throw new Error('Server error');
      }
    } catch {
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      btnText.textContent = 'Enviar mensaje';
      btnSpinner.classList.add('hidden');
    }
  });
</script>
