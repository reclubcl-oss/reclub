---
---

<section
  class="relative flex flex-col items-center justify-center overflow-hidden bg-brand-black pt-20"
  style="min-height: 100svh;"
>
  <!-- Background grid -->
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(30,41,59,0.25)_1px,transparent_1px),linear-gradient(90deg,rgba(30,41,59,0.25)_1px,transparent_1px)] bg-[size:60px_60px]"
  >
  </div>

  <!-- Radial glow -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(59,130,246,0.15),transparent)]"
  >
  </div>

  <!-- Animated blobs -->
  <div
    class="absolute top-1/4 left-1/4 w-72 h-72 bg-brand-blue/10 rounded-full blur-3xl animate-blob"
  >
  </div>
  <div
    class="absolute top-1/3 right-1/4 w-72 h-72 bg-brand-purple/10 rounded-full blur-3xl animate-blob animation-delay-2000"
  >
  </div>
  <div
    class="absolute bottom-1/4 left-1/2 w-56 h-56 bg-brand-blue/8 rounded-full blur-3xl animate-blob animation-delay-4000"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 text-center">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 border border-brand-blue/30 bg-brand-blue/10 text-brand-blue text-sm px-4 py-1.5 rounded-full mb-8"
      data-aos="fade-down"
    >
      <span class="w-2 h-2 bg-brand-blue rounded-full animate-pulse"></span>
      Agencia Digital Chilena
    </div>

    <!-- Headline -->
    <h1
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight mb-6 tracking-tight"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      Digitaliza tu negocio con{' '}
      <span
        class="bg-gradient-to-r from-brand-blue to-brand-purple bg-clip-text text-transparent"
      >
        ReClub
      </span>
    </h1>

    <!-- Subtitle -->
    <p
      class="text-brand-muted text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      Webs, fidelización y contenido — todo en un solo lugar
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row gap-3 justify-center w-full max-w-sm sm:max-w-none mx-auto"
      data-aos="fade-up"
      data-aos-delay="300"
    >
      <a
        href="#servicios"
        class="bg-gradient-to-r from-brand-blue to-brand-purple text-white px-8 py-4 rounded-xl font-semibold hover:scale-105 active:scale-95 transition-transform duration-200 shadow-lg shadow-brand-blue/25 w-full sm:w-auto text-center"
      >
        Ver Servicios
      </a>
      <a
        href="#contacto"
        class="border border-brand-border text-brand-white px-8 py-4 rounded-xl font-semibold hover:border-brand-blue/50 hover:bg-brand-blue/5 active:bg-brand-blue/10 transition-all duration-200 w-full sm:w-auto text-center"
      >
        Contáctanos
      </a>
    </div>

    <!-- Stats row -->
    <div
      class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto"
      data-aos="fade-up"
      data-aos-delay="400"
    >
      <div class="text-center">
        <p class="text-2xl font-bold text-brand-white">5+</p>
        <p class="text-brand-muted text-sm mt-1">Años de experiencia</p>
      </div>
      <div
        class="text-center border-x border-brand-border"
      >
        <p class="text-2xl font-bold text-brand-white">100+</p>
        <p class="text-brand-muted text-sm mt-1">Clientes satisfechos</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-bold text-brand-white">3</p>
        <p class="text-brand-muted text-sm mt-1">Servicios integrados</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-6 h-6 text-brand-muted"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19.5 8.25l-7.5 7.5-7.5-7.5"
      ></path>
    </svg>
  </div>
</section>
