---
// Prefijo para links de ancla — desde otras páginas necesita ir a /#seccion
const base = Astro.url.pathname === '/' ? '' : '/';
---

<nav
  id="navbar"
  class="fixed top-0 w-full z-50 transition-all duration-300 py-4 px-4"
  style="padding-top: max(1rem, env(safe-area-inset-top));"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-2xl font-bold tracking-tight">
      Re<span class="text-brand-blue">Club</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      <a
        href={`${base}#servicios`}
        class="text-brand-muted hover:text-brand-white transition-colors text-sm font-medium"
      >
        Servicios
      </a>
      <a
        href={`${base}#por-que-reclub`}
        class="text-brand-muted hover:text-brand-white transition-colors text-sm font-medium"
      >
        Por qué ReClub
      </a>
      <a
        href={`${base}#contacto`}
        class="bg-brand-blue hover:bg-brand-blue-dark text-white px-5 py-2 rounded-lg text-sm font-semibold transition-colors"
      >
        Empezar
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="md:hidden text-brand-muted hover:text-brand-white transition-colors p-2"
      aria-label="Abrir menú"
    >
      <svg
        id="icon-open"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
        ></path>
      </svg>
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6 hidden"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden mt-4 pb-4 border-t border-brand-border"
  >
    <div class="flex flex-col gap-4 pt-4 px-4">
      <a
        href={`${base}#servicios`}
        class="mobile-link text-brand-muted hover:text-brand-white transition-colors font-medium"
      >
        Servicios
      </a>
      <a
        href={`${base}#por-que-reclub`}
        class="mobile-link text-brand-muted hover:text-brand-white transition-colors font-medium"
      >
        Por qué ReClub
      </a>
      <a
        href={`${base}#contacto`}
        class="mobile-link bg-brand-blue hover:bg-brand-blue-dark text-white px-5 py-3 rounded-lg font-semibold text-center transition-colors"
      >
        Empezar
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('navbar') as HTMLElement;
  const menuBtn = document.getElementById('menu-btn') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  const iconOpen = document.getElementById('icon-open') as HTMLElement;
  const iconClose = document.getElementById('icon-close') as HTMLElement;

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav.classList.add(
        'bg-brand-dark/95',
        'backdrop-blur-md',
        'shadow-lg',
        'shadow-black/20',
        'py-2',
      );
      nav.classList.remove('py-4');
    } else {
      nav.classList.remove(
        'bg-brand-dark/95',
        'backdrop-blur-md',
        'shadow-lg',
        'shadow-black/20',
        'py-2',
      );
      nav.classList.add('py-4');
    }
  });

  // Mobile menu toggle
  menuBtn.addEventListener('click', () => {
    const isHidden = mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', !isHidden);
    iconOpen.classList.toggle('hidden', !isHidden);
    iconClose.classList.toggle('hidden', isHidden);
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
