---
const reasons = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    color: 'text-brand-blue',
    bg: 'bg-brand-blue/10',
    title: 'Todo en un solo lugar',
    description:
      'Web, fidelización y contenido sin necesidad de contratar 3 agencias distintas. Una sola factura, un solo equipo.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    color: 'text-brand-purple',
    bg: 'bg-brand-purple/10',
    title: 'Precios claros',
    description:
      'Sin contratos trampa ni permanencia mínima. Planes mensuales transparentes. Cancela cuando quieras, sin explicaciones.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
    color: 'text-emerald-400',
    bg: 'bg-emerald-400/10',
    title: 'Equipo local',
    description:
      'Somos un equipo chileno que entiende tu mercado, habla tu idioma y está disponible cuando lo necesitas. Sin diferencia horaria.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
    color: 'text-amber-400',
    bg: 'bg-amber-400/10',
    title: 'Resultados reales',
    description:
      'Métricas claras desde el primer mes. Sabes exactamente lo que obtienes, con reportes que puedes entender.',
  },
];
---

<section id="por-que-reclub" class="py-24 px-4 bg-brand-black">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16" data-aos="fade-up">
      <p class="text-brand-blue text-sm font-semibold tracking-widest uppercase mb-3">
        Por qué elegirnos
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-white mb-4">
        La diferencia ReClub
      </h2>
      <div class="w-16 h-1 bg-gradient-to-r from-brand-blue to-brand-purple rounded mx-auto"></div>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        reasons.map((reason, i) => (
          <div
            class="bg-brand-card border border-brand-border rounded-2xl p-6 text-center hover:border-brand-blue/30 hover:-translate-y-1 transition-all duration-300"
            data-aos="fade-up"
            data-aos-delay={i * 100}
          >
            <div class={`w-16 h-16 ${reason.bg} rounded-2xl flex items-center justify-center mx-auto mb-5 ${reason.color}`}>
              <Fragment set:html={reason.icon} />
            </div>
            <h3 class="text-lg font-bold text-brand-white mb-3">{reason.title}</h3>
            <p class="text-brand-muted text-sm leading-relaxed">{reason.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
