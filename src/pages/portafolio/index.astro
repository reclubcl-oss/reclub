---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { supabaseAdmin } from '../../lib/supabase';

// Sin caché — siempre datos frescos
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Surrogate-Control', 'no-store');

let videos: any[] = [];
let brands: any[] = [];

try {
  const [vRes, bRes] = await Promise.all([
    supabaseAdmin.from('portfolio_videos').select('*').order('sort_order').order('created_at', { ascending: false }),
    supabaseAdmin.from('portfolio_brands').select('*').order('sort_order'),
  ]);
  videos = vRes.data ?? [];
  brands = bRes.data ?? [];
} catch (_) {}

function pub(path: string) {
  return supabaseAdmin.storage.from('portfolio').getPublicUrl(path).data.publicUrl;
}

const videosReady = videos.map(v => ({
  ...v,
  videoUrl: pub(v.video_path),
  thumbUrl: v.thumbnail_path ? pub(v.thumbnail_path) : null,
}));

const brandsReady = brands.map(b => ({
  ...b,
  logoUrl: b.logo_path ? pub(b.logo_path) : null,
}));

const totalBrands = brandsReady.length;
---

<Layout
  title="Portafolio — ReClub Agencia Digital"
  description="Videos y marcas de ReClub. Más de 60+ empresas han confiado en nosotros."
>
  <Nav />
  <main>

    <!-- HERO -->
    <section class="relative flex flex-col items-center justify-center overflow-hidden bg-brand-black pt-20" style="min-height:100svh;">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(30,41,59,0.25)_1px,transparent_1px),linear-gradient(90deg,rgba(30,41,59,0.25)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(59,130,246,0.15),transparent)]"></div>
      <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-brand-blue/10 rounded-full blur-3xl animate-blob"></div>
      <div class="absolute top-1/3 right-1/4 w-72 h-72 bg-brand-purple/10 rounded-full blur-3xl animate-blob animation-delay-2000"></div>
      <div class="absolute bottom-1/4 left-1/2 w-56 h-56 bg-brand-blue/8 rounded-full blur-3xl animate-blob animation-delay-4000"></div>

      <div class="relative z-10 max-w-5xl mx-auto px-4 text-center">
        <div class="inline-flex items-center gap-2 border border-brand-blue/30 bg-brand-blue/10 text-brand-blue text-sm px-4 py-1.5 rounded-full mb-8" data-aos="fade-down">
          <span class="w-2 h-2 bg-brand-blue rounded-full animate-pulse"></span>
          Nuestro Trabajo
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight mb-6 tracking-tight" data-aos="fade-up" data-aos-delay="100">
          Resultados reales para<br />
          <span class="bg-gradient-to-r from-brand-blue to-brand-purple bg-clip-text text-transparent">
            marcas reales
          </span>
        </h1>

        <p class="text-brand-muted text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed" data-aos="fade-up" data-aos-delay="200">
          Videos y campañas digitales que conectan marcas con su audiencia.<br class="hidden md:block" />
          Esto es lo que hacemos en ReClub.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center w-full max-w-sm sm:max-w-none mx-auto" data-aos="fade-up" data-aos-delay="300">
          <a href="#videos" class="bg-gradient-to-r from-brand-blue to-brand-purple text-white px-8 py-4 rounded-xl font-semibold hover:scale-105 active:scale-95 transition-transform duration-200 shadow-lg shadow-brand-blue/25 text-center">
            Ver videos
          </a>
          <a href="/#contacto" class="border border-brand-border text-brand-white px-8 py-4 rounded-xl font-semibold hover:border-brand-blue/50 hover:bg-brand-blue/5 transition-all duration-200 text-center">
            Trabajemos juntos
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto" data-aos="fade-up" data-aos-delay="400">
          <div class="text-center">
            <p class="text-2xl font-bold text-brand-white">{videosReady.length}+</p>
            <p class="text-brand-muted text-sm mt-1">Videos</p>
          </div>
          <div class="text-center border-x border-brand-border">
            <p class="text-2xl font-bold text-brand-white">{totalBrands > 60 ? `${totalBrands}+` : '60+'}</p>
            <p class="text-brand-muted text-sm mt-1">Marcas</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-brand-white">100%</p>
            <p class="text-brand-muted text-sm mt-1">Dedicación</p>
          </div>
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-muted">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
        </svg>
      </div>
    </section>

    <!-- VIDEOS -->
    <section id="videos" class="py-24 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16" data-aos="fade-up">
          <div class="inline-flex items-center gap-2 border border-brand-blue/30 bg-brand-blue/10 text-brand-blue text-xs px-3 py-1 rounded-full mb-4">
            Videos
          </div>
          <h2 class="text-3xl md:text-5xl font-extrabold text-brand-white mb-4">Nuestros Proyectos</h2>
          <p class="text-brand-muted text-lg max-w-xl mx-auto">Cada video cuenta una historia. Aquí están las nuestras.</p>
        </div>

        {videosReady.length === 0 ? (
          <div class="text-center py-32 text-brand-muted">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 10l4.553-2.369A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <p class="text-lg font-medium">Videos próximamente</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            {videosReady.map((v, i) => (
              <article
                class="group relative bg-brand-card border border-brand-border rounded-2xl overflow-hidden cursor-pointer hover:border-brand-blue/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_40px_rgba(59,130,246,0.12)]"
                data-aos="fade-up"
                data-aos-delay={Math.min(i * 80, 400)}
                data-video-url={v.videoUrl}
                data-video-title={v.title}
                data-video-desc={v.description}
              >
                <div class="aspect-video bg-brand-dark relative overflow-hidden">
                  {v.thumbUrl ? (
                    <img src={v.thumbUrl} alt={v.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-brand-blue/10 to-brand-purple/10">
                      <svg class="w-14 h-14 text-brand-muted/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                  )}
                  <div class="absolute inset-0 bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-2xl scale-90 group-hover:scale-100 transition-transform duration-300">
                      <svg class="w-7 h-7 text-brand-black ml-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                  {v.category && v.category !== 'general' && (
                    <span class="absolute top-3 left-3 bg-brand-black/70 backdrop-blur-sm text-brand-white text-xs px-3 py-1 rounded-full border border-brand-border/50 capitalize">
                      {v.category}
                    </span>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="font-bold text-brand-white text-base mb-1.5 line-clamp-1">{v.title}</h3>
                  {v.description && (
                    <p class="text-brand-muted text-sm line-clamp-2 leading-relaxed">{v.description}</p>
                  )}
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- MARCAS -->
    <section id="marcas" class="py-24 px-4 bg-brand-dark">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16" data-aos="fade-up">
          <div class="inline-flex items-center gap-2 border border-brand-purple/30 bg-brand-purple/10 text-brand-purple text-xs px-3 py-1 rounded-full mb-4">
            Clientes
          </div>
          <h2 class="text-3xl md:text-5xl font-extrabold text-brand-white mb-4">
            Marcas que Confiaron en ReClub
          </h2>
          <p class="text-brand-muted text-lg max-w-xl mx-auto">
            Más de {totalBrands > 60 ? totalBrands : '60'}+ empresas eligieron a ReClub para hacer crecer su presencia digital.
          </p>
        </div>

        {brandsReady.length === 0 ? (
          <div class="text-center py-20 text-brand-muted">
            <p class="text-lg font-medium">Marcas próximamente</p>
          </div>
        ) : (
          <>
            <div id="brandsGrid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8 gap-3" data-aos="fade-up" data-aos-delay="100">
              {brandsReady.map((b, i) => (
                <div class={`brand-card group bg-brand-card border border-brand-border rounded-xl p-3 flex items-center justify-center min-h-[72px] hover:border-brand-blue/40 transition-all duration-300${i >= 60 ? ' brand-extra hidden' : ''}`}>
                  {b.logoUrl ? (
                    <img src={b.logoUrl} alt={b.name} class="max-h-8 max-w-full object-contain filter grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" loading="lazy" />
                  ) : (
                    <span class="text-brand-muted group-hover:text-brand-white font-medium text-xs text-center transition-colors leading-tight">{b.name}</span>
                  )}
                </div>
              ))}
            </div>

            {brandsReady.length > 60 && (
              <div class="text-center mt-10">
                <button id="showAllBrands" class="inline-flex items-center gap-2 border border-brand-border hover:border-brand-blue/50 text-brand-muted hover:text-brand-white px-8 py-3 rounded-full text-sm font-semibold transition-all duration-300">
                  <svg id="showAllIcon" class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                  <span id="showAllText">Ver todas las marcas ({brandsReady.length})</span>
                </button>
              </div>
            )}
          </>
        )}
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-4">
      <div class="max-w-4xl mx-auto" data-aos="fade-up">
        <div class="relative overflow-hidden rounded-3xl border border-brand-border bg-gradient-to-br from-brand-card to-brand-dark p-12 md:p-16 text-center">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_0%,rgba(59,130,246,0.1),transparent)] pointer-events-none"></div>
          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 border border-brand-blue/30 bg-brand-blue/10 text-brand-blue text-xs px-3 py-1 rounded-full mb-6">¿Listo para crecer?</div>
            <h2 class="text-3xl md:text-5xl font-extrabold text-brand-white mb-5">Hagamos crecer<br class="hidden md:block" /> tu marca juntos</h2>
            <p class="text-brand-muted text-lg mb-10 max-w-xl mx-auto">Únete a las más de {totalBrands > 60 ? totalBrands : 60}+ marcas que ya confían en ReClub.</p>
            <a href="/#contacto" class="bg-gradient-to-r from-brand-blue to-brand-purple text-white px-10 py-4 rounded-xl font-semibold hover:scale-105 active:scale-95 transition-transform duration-200 shadow-lg shadow-brand-blue/25 inline-block">
              Empezar ahora
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
  <WhatsAppButton />

  <!-- VIDEO MODAL -->
  <div id="videoModal" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-sm flex items-center justify-center p-4 hidden" aria-modal="true" role="dialog">
    <div class="relative w-full max-w-5xl">
      <button id="closeModalBtn" class="absolute -top-12 right-0 text-white/60 hover:text-white transition-colors flex items-center gap-2 text-sm" aria-label="Cerrar">
        <kbd class="text-xs border border-white/20 rounded px-1.5 py-0.5">ESC</kbd>
        Cerrar
      </button>
      <div class="bg-brand-card rounded-2xl overflow-hidden shadow-2xl border border-brand-border">
        <video id="modalVideo" controls playsinline class="w-full aspect-video bg-black"></video>
        <div class="p-6 border-t border-brand-border">
          <h3 id="modalTitle" class="text-xl font-bold text-brand-white mb-1"></h3>
          <p id="modalDesc" class="text-brand-muted text-sm leading-relaxed"></p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Video modal
  const videoModal = document.getElementById('videoModal') as HTMLElement;
  const modalVideo = document.getElementById('modalVideo') as HTMLVideoElement;
  const modalTitle = document.getElementById('modalTitle') as HTMLElement;
  const modalDesc  = document.getElementById('modalDesc') as HTMLElement;

  function openModal(el: HTMLElement) {
    modalVideo.src = el.dataset.videoUrl!;
    modalTitle.textContent = el.dataset.videoTitle ?? '';
    modalDesc.textContent  = el.dataset.videoDesc  ?? '';
    videoModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    modalVideo.play().catch(() => {});
  }
  function closeModal() {
    modalVideo.pause(); modalVideo.src = '';
    videoModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('article[data-video-url]').forEach(c =>
    c.addEventListener('click', () => openModal(c as HTMLElement))
  );
  videoModal.addEventListener('click', e => { if (e.target === videoModal) closeModal(); });
  document.getElementById('closeModalBtn')?.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // Mostrar todas las marcas
  const showAllBtn  = document.getElementById('showAllBrands');
  const showAllText = document.getElementById('showAllText');
  const showAllIcon = document.getElementById('showAllIcon') as HTMLElement | null;
  let expanded = false;

  showAllBtn?.addEventListener('click', () => {
    expanded = !expanded;
    document.querySelectorAll<HTMLElement>('.brand-extra').forEach(el =>
      el.classList.toggle('hidden', !expanded)
    );
    if (showAllIcon) showAllIcon.style.transform = expanded ? 'rotate(180deg)' : '';
    if (showAllText) {
      const total = document.querySelectorAll('.brand-card').length;
      showAllText.textContent = expanded ? 'Ver menos' : `Ver todas las marcas (${total})`;
    }
  });
</script>
