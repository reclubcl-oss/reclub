---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Panel de Negocio — ReClub">
  <main class="min-h-screen bg-brand-black px-4 py-8 flex flex-col" style="padding-bottom: max(2rem, env(safe-area-inset-bottom));">

    <!-- Login view -->
    <div id="login-view" class="max-w-sm mx-auto w-full flex-1 flex flex-col justify-center">
      <div class="text-center mb-10">
        <a href="/" class="text-2xl font-bold text-brand-white">Re<span class="text-brand-blue">Club</span></a>
        <p class="text-brand-muted mt-2 text-sm">Panel de negocio</p>
      </div>

      <form id="login-form" class="flex flex-col gap-4">
        <input
          type="email" id="login-email" placeholder="Email del negocio" required
          autocomplete="username"
          class="bg-brand-card border border-brand-border rounded-xl px-4 py-3 text-brand-white placeholder:text-brand-muted/60 focus:outline-none focus:border-brand-blue transition-colors"
        />
        <input
          type="password" id="login-password" placeholder="Contraseña" required
          autocomplete="current-password"
          class="bg-brand-card border border-brand-border rounded-xl px-4 py-3 text-brand-white placeholder:text-brand-muted/60 focus:outline-none focus:border-brand-blue transition-colors"
        />
        <p id="login-error" class="text-red-400 text-sm text-center hidden"></p>
        <button
          type="submit" id="login-btn"
          class="bg-brand-blue text-white font-semibold rounded-xl py-4 hover:bg-brand-blue-dark active:scale-95 transition-all"
        >
          Iniciar sesión
        </button>
      </form>
    </div>

    <!-- Dashboard view (hidden until logged in) -->
    <div id="dashboard-view" class="hidden max-w-lg mx-auto w-full">

      <!-- Header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-xl font-bold text-brand-white" id="business-name">Panel</h1>
          <p class="text-brand-muted text-sm" id="business-type"></p>
        </div>
        <button id="logout-btn" class="text-brand-muted text-sm hover:text-brand-white transition-colors">
          Salir
        </button>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-4 mb-8">
        <div class="bg-brand-card border border-brand-border rounded-2xl p-4">
          <p class="text-brand-muted text-xs mb-1">Clientes totales</p>
          <p class="text-2xl font-bold text-brand-blue" id="stat-clients">—</p>
        </div>
        <div class="bg-brand-card border border-brand-border rounded-2xl p-4">
          <p class="text-brand-muted text-xs mb-1">Sellos hoy</p>
          <p class="text-2xl font-bold text-brand-purple" id="stat-today">—</p>
        </div>
      </div>

      <!-- Primary action -->
      <a
        href="/dashboard/scan"
        class="flex items-center justify-center gap-3 w-full bg-gradient-to-r from-brand-blue to-brand-purple text-white font-bold text-lg rounded-2xl py-5 mb-4 hover:scale-[1.02] active:scale-95 transition-transform shadow-lg shadow-brand-blue/25"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM13.5 18.75h.75v.75h-.75v-.75zM18.75 13.5h.75v.75h-.75v-.75zM18.75 18.75h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75z" />
        </svg>
        Escanear QR del cliente
      </a>

      <!-- Recent transactions -->
      <div id="recent-transactions" class="bg-brand-card border border-brand-border rounded-2xl p-5">
        <h3 class="font-semibold text-brand-white mb-4 text-sm">Actividad reciente</h3>
        <div id="transactions-list" class="flex flex-col gap-3">
          <p class="text-brand-muted text-sm">Cargando...</p>
        </div>
      </div>
    </div>

  </main>
</Layout>

<script>
  import { supabase } from '../../lib/supabase-browser';

  const loginView = document.getElementById('login-view')!;
  const dashboardView = document.getElementById('dashboard-view')!;
  const loginForm = document.getElementById('login-form') as HTMLFormElement;
  const loginError = document.getElementById('login-error')!;
  const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;

  let currentBusiness: any = null;

  async function checkSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) await showDashboard(session);
  }

  async function showDashboard(session: any) {
    loginView.classList.add('hidden');
    dashboardView.classList.remove('hidden');

    // Load business data
    const { data: business } = await supabase
      .from('businesses')
      .select('*')
      .eq('owner_id', session.user.id)
      .single();

    if (!business) return;
    currentBusiness = business;

    document.getElementById('business-name')!.textContent = business.name;
    document.getElementById('business-type')!.textContent =
      business.loyalty_type === 'stamps' ? 'Programa de sellos' : 'Programa de puntos';

    // Load stats
    const { count: clientCount } = await supabase
      .from('loyalty_cards')
      .select('*', { count: 'exact', head: true })
      .eq('business_id', business.id);

    document.getElementById('stat-clients')!.textContent = String(clientCount ?? 0);

    const todayStart = new Date();
    todayStart.setHours(0, 0, 0, 0);

    const { count: todayCount } = await supabase
      .from('transactions')
      .select('*, card:loyalty_cards!inner(business_id)', { count: 'exact', head: true })
      .eq('card.business_id', business.id)
      .gte('created_at', todayStart.toISOString());

    document.getElementById('stat-today')!.textContent = String(todayCount ?? 0);

    // Load recent transactions
    const { data: txns } = await supabase
      .from('transactions')
      .select('*, card:loyalty_cards!inner(business_id, client:clients(name, phone))')
      .eq('card.business_id', business.id)
      .order('created_at', { ascending: false })
      .limit(5);

    const list = document.getElementById('transactions-list')!;
    if (!txns || txns.length === 0) {
      list.innerHTML = '<p class="text-brand-muted text-sm">Sin actividad reciente.</p>';
    } else {
      list.innerHTML = txns.map((t: any) => {
        const client = t.card?.client;
        const name = client?.name || client?.phone || 'Cliente';
        const date = new Date(t.created_at).toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' });
        return `
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-brand-blue/20 flex items-center justify-center text-brand-blue text-xs font-bold">${name[0].toUpperCase()}</div>
              <span class="text-brand-white text-sm">${name}</span>
            </div>
            <div class="text-right">
              <span class="text-brand-blue text-sm font-medium">+${t.amount} ${t.type === 'stamp' ? 'sello' : 'pts'}</span>
              <p class="text-brand-muted text-xs">${date}</p>
            </div>
          </div>`;
      }).join('');
    }
  }

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginBtn.textContent = 'Entrando...';
    loginBtn.disabled = true;
    loginError.classList.add('hidden');

    const email = (document.getElementById('login-email') as HTMLInputElement).value;
    const password = (document.getElementById('login-password') as HTMLInputElement).value;

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error || !data.session) {
      loginError.textContent = 'Email o contraseña incorrectos';
      loginError.classList.remove('hidden');
      loginBtn.textContent = 'Iniciar sesión';
      loginBtn.disabled = false;
    } else {
      await showDashboard(data.session);
    }
  });

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    dashboardView.classList.add('hidden');
    loginView.classList.remove('hidden');
    loginBtn.textContent = 'Iniciar sesión';
    loginBtn.disabled = false;
  });

  checkSession();
</script>
